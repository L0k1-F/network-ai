{
  "vendor": "Arista",
  "categories": {
    "vlan": {
      "name": "VLAN配置",
      "commands": [
        {"name": "进入配置模式", "syntax": "configure [terminal|session <name>]", "example": "configure", "description": "进入全局配置模式", "mode": "特权模式"},
        {"name": "创建VLAN", "syntax": "vlan <vlan_id>\n  name <vlan_name>", "example": "vlan 10\n  name Management", "description": "创建VLAN并设置名称", "mode": "全局配置"},
        {"name": "批量创建VLAN", "syntax": "vlan <id1>,<id2>-<id3>", "example": "vlan 10,20,30-35", "description": "批量创建VLAN，支持逗号和范围", "mode": "全局配置"},
        {"name": "接口Access模式", "syntax": "switchport mode access\n  switchport access vlan <vlan_id>", "example": "interface Ethernet1\n  switchport mode access\n  switchport access vlan 10", "description": "将接口设为Access模式", "mode": "接口配置"},
        {"name": "接口Trunk模式", "syntax": "switchport mode trunk\n  switchport trunk allowed vlan <vlan_list>", "example": "switchport mode trunk\n  switchport trunk allowed vlan 10,20,30", "description": "将接口设为Trunk模式", "mode": "接口配置"},
        {"name": "设置Native VLAN", "syntax": "switchport trunk native vlan <vlan_id>", "example": "switchport trunk native vlan 1", "description": "设置Trunk端口的Native VLAN", "mode": "接口配置"},
        {"name": "路由模式接口", "syntax": "no switchport", "example": "no switchport\n  ip address 10.1.1.1/30", "description": "将二层接口转为三层路由接口（Arista默认二层）", "mode": "接口配置"},
        {"name": "创建SVI", "syntax": "interface Vlan<id>\n  ip address <ip>/<prefix>", "example": "interface Vlan10\n  ip address 192.168.10.1/24", "description": "创建SVI三层VLAN接口", "mode": "全局配置"},
        {"name": "查看VLAN", "syntax": "show vlan [<vlan_id>|summary]", "example": "show vlan summary", "description": "查看VLAN信息", "mode": "特权模式"}
      ],
      "keywords": ["vlan", "switchport", "access", "trunk", "native", "svi", "no switchport"]
    },
    "stp": {
      "name": "STP/MSTP配置",
      "commands": [
        {"name": "启用STP", "syntax": "spanning-tree mode {mstp|rstp|rapid-pvst}", "example": "spanning-tree mode mstp", "description": "选择生成树模式", "mode": "全局配置"},
        {"name": "设置优先级", "syntax": "spanning-tree priority <0-61440 step 4096>", "example": "spanning-tree priority 4096", "description": "设置交换机STP优先级", "mode": "全局配置"},
        {"name": "配置MST", "syntax": "spanning-tree mst configuration\n  name <region_name>\n  revision <level>\n  instance <id> vlan <vlan_list>", "example": "spanning-tree mst configuration\n  name REGION1\n  revision 1\n  instance 1 vlan 10,20", "description": "配置MST域参数", "mode": "全局配置"},
        {"name": "边缘端口", "syntax": "spanning-tree portfast [auto]", "example": "spanning-tree portfast", "description": "将接口设为边缘端口", "mode": "接口配置"},
        {"name": "BPDU保护", "syntax": "spanning-tree bpduguard enable", "example": "spanning-tree bpduguard enable", "description": "启用BPDU Guard", "mode": "全局配置"},
        {"name": "查看STP", "syntax": "show spanning-tree [detail]", "example": "show spanning-tree detail", "description": "查看生成树状态", "mode": "特权模式"}
      ],
      "keywords": ["spanning-tree", "mstp", "rstp", "portfast", "bpduguard", "mst"]
    },
    "aggregation": {
      "name": "链路聚合",
      "commands": [
        {"name": "创建Port-Channel", "syntax": "interface Port-Channel <id>", "example": "interface Port-Channel 1\n  switchport mode trunk", "description": "创建Port-Channel逻辑接口", "mode": "全局配置"},
        {"name": "加入Port-Channel", "syntax": "channel-group <id> mode {active|passive|on}", "example": "channel-group 1 mode active", "description": "将物理接口加入聚合组", "mode": "接口配置"},
        {"name": "负载均衡", "syntax": "port-channel load-balance {src-ip|dst-ip|src-dst-ip|src-mac}", "example": "port-channel load-balance src-dst-ip", "description": "配置负载均衡算法", "mode": "全局配置"},
        {"name": "MLAG对等体", "syntax": "mlag configuration\n  domain-id <id>\n  local-interface Vlan<id>\n  peer-address <ip>\n  peer-link Port-Channel <id>", "example": "mlag configuration\n  domain-id MLAG1\n  local-interface Vlan4094\n  peer-address 10.255.255.1\n  peer-link Port-Channel 1000", "description": "配置MLAG（Arista核心技术，多机箱LAG）", "mode": "全局配置"},
        {"name": "查看MLAG", "syntax": "show mlag [detail]", "example": "show mlag detail", "description": "查看MLAG对等体状态", "mode": "特权模式"},
        {"name": "查看Port-Channel", "syntax": "show port-channel [summary|detailed]", "example": "show port-channel summary", "description": "查看聚合接口状态", "mode": "特权模式"}
      ],
      "keywords": ["port-channel", "mlag", "lacp", "链路聚合", "channel-group", "负载均衡"]
    },
    "routing": {
      "name": "路由协议",
      "commands": [
        {"name": "配置静态路由", "syntax": "ip route <dest_ip>/<prefix> <next_hop> [<distance>]", "example": "ip route 192.168.2.0/24 10.1.1.1", "description": "添加静态路由", "mode": "全局配置"},
        {"name": "配置默认路由", "syntax": "ip route 0.0.0.0/0 <next_hop>", "example": "ip route 0.0.0.0/0 10.1.1.1", "description": "配置默认路由", "mode": "全局配置"},
        {"name": "启用OSPF", "syntax": "router ospf <process_id>\n  router-id <id>", "example": "router ospf 1\n  router-id 1.1.1.1", "description": "创建OSPF进程", "mode": "全局配置"},
        {"name": "宣告网络", "syntax": "network <ip>/<prefix> area <area>", "example": "network 10.1.1.0/24 area 0.0.0.0", "description": "宣告OSPF网络（Arista使用前缀格式）", "mode": "OSPF路由配置"},
        {"name": "被动接口", "syntax": "passive-interface <interface>", "example": "passive-interface Ethernet1", "description": "设置被动接口", "mode": "OSPF路由配置"},
        {"name": "启用BGP", "syntax": "router bgp <as_number>\n  router-id <id>", "example": "router bgp 65001\n  router-id 1.1.1.1", "description": "启用BGP", "mode": "全局配置"},
        {"name": "配置BGP邻居", "syntax": "neighbor <ip> remote-as <as>", "example": "neighbor 10.1.1.2 remote-as 65002", "description": "配置BGP对等体", "mode": "BGP路由配置"},
        {"name": "路由表", "syntax": "show ip route [<prefix>]", "example": "show ip route 0.0.0.0/0", "description": "查看路由表", "mode": "特权模式"},
        {"name": "BGP邻居", "syntax": "show ip bgp summary", "example": "show ip bgp summary", "description": "查看BGP邻居摘要", "mode": "特权模式"}
      ],
      "keywords": ["静态路由", "ospf", "bgp", "router-id", "passive-interface", "路由表", "bgp summary"]
    },
    "acl": {
      "name": "ACL/安全配置",
      "commands": [
        {"name": "创建标准ACL", "syntax": "ip access-list standard <name>\n  <seq> permit|deny <src_ip>/<prefix>", "example": "ip access-list standard MGMT\n  10 permit 192.168.99.0/24", "description": "创建命名标准ACL", "mode": "全局配置"},
        {"name": "创建扩展ACL", "syntax": "ip access-list <name>\n  <seq> permit|deny <protocol> <src> <dst> [<port>]", "example": "ip access-list BLOCK_SSH\n  10 deny tcp any any eq 22", "description": "创建命名扩展ACL", "mode": "全局配置"},
        {"name": "接口应用ACL", "syntax": "ip access-group <acl_name> {in|out}", "example": "ip access-group BLOCK_SSH in", "description": "在接口方向应用ACL", "mode": "接口配置"},
        {"name": "控制平面ACL", "syntax": "system control-plane\n  ip access-group <acl_name> in", "example": "system control-plane\n  ip access-group MGMT_ACL in", "description": "应用ACL到控制平面保护CPU", "mode": "全局配置"},
        {"name": "查看ACL", "syntax": "show ip access-lists [<name>]", "example": "show ip access-lists BLOCK_SSH", "description": "查看ACL规则和计数器", "mode": "特权模式"}
      ],
      "keywords": ["acl", "access-list", "access-group", "控制平面", "permit", "deny", "过滤"]
    },
    "dhcp": {
      "name": "DHCP配置",
      "commands": [
        {"name": "启用DHCP中继", "syntax": "ip dhcp relay information option", "example": "ip dhcp relay information option", "description": "全局启用DHCP中继Option 82", "mode": "全局配置"},
        {"name": "接口DHCP中继", "syntax": "ip helper-address <dhcp_server_ip>", "example": "ip helper-address 192.168.1.10", "description": "在SVI上配置DHCP中继地址", "mode": "接口配置"},
        {"name": "本地DHCP服务器", "syntax": "dhcp server\n  subnet <network>/<prefix>\n  range <start> <end>\n  default-gateway <ip>\n  dns-server <ip>", "example": "dhcp server\n  subnet 192.168.1.0/24\n  range 192.168.1.10 192.168.1.250", "description": "配置本地DHCP服务器", "mode": "全局配置"},
        {"name": "查看DHCP绑定", "syntax": "show ip dhcp binding", "example": "show ip dhcp binding", "description": "查看DHCP绑定表", "mode": "特权模式"}
      ],
      "keywords": ["dhcp", "dhcp relay", "ip helper-address", "地址池", "dhcp server", "dhcp snooping"]
    },
    "vrrp": {
      "name": "VRRP配置",
      "commands": [
        {"name": "创建VRRP", "syntax": "vrrp <group_id> ip <virtual_ip>", "example": "vrrp 1 ip 192.168.1.254", "description": "在接口上创建VRRP备份组", "mode": "接口配置"},
        {"name": "设置优先级", "syntax": "vrrp <group_id> priority <1-255>", "example": "vrrp 1 priority 120", "description": "设置VRRP优先级", "mode": "接口配置"},
        {"name": "抢占", "syntax": "vrrp <group_id> preempt [delay minimum <seconds>]", "example": "vrrp 1 preempt delay minimum 30", "description": "启用VRRP抢占模式", "mode": "接口配置"},
        {"name": "查看VRRP", "syntax": "show vrrp [detail]", "example": "show vrrp detail", "description": "查看VRRP状态", "mode": "特权模式"}
      ],
      "keywords": ["vrrp", "虚拟网关", "vrrp group", "优先级", "抢占", "virtual-ip"]
    },
    "management": {
      "name": "管理运维",
      "commands": [
        {"name": "设置主机名", "syntax": "hostname <name>", "example": "hostname Core-SW-01", "description": "设置设备主机名", "mode": "全局配置"},
        {"name": "配置管理接口", "syntax": "interface Management1\n  ip address <ip>/<prefix>", "example": "interface Management1\n  ip address 192.168.1.1/24", "description": "配置带外管理接口（Arista管理口为Management1）", "mode": "全局配置"},
        {"name": "配置管理路由", "syntax": "ip route 0.0.0.0/0 <gw> (管理VRF)", "example": "ip route 0.0.0.0/0 192.168.1.254", "description": "为管理接口配置默认路由", "mode": "全局配置"},
        {"name": "配置SSH", "syntax": "management ssh\n  idle-timeout <minutes>", "example": "management ssh\n  idle-timeout 15", "description": "SSH管理设置（Arista默认启用SSH）", "mode": "全局配置"},
        {"name": "创建用户", "syntax": "username <user> privilege <0-15> secret <password>", "example": "username admin privilege 15 secret P@ssw0rd", "description": "创建本地用户", "mode": "全局配置"},
        {"name": "配置NTP", "syntax": "ntp server <ip> [prefer] [iburst]", "example": "ntp server 192.168.1.100 prefer iburst", "description": "配置NTP服务器", "mode": "全局配置"},
        {"name": "配置SNMP", "syntax": "snmp-server community <community> ro", "example": "snmp-server community public ro", "description": "配置SNMP只读团体字", "mode": "全局配置"},
        {"name": "保存配置", "syntax": "write memory 或 copy running-config startup-config", "example": "copy running-config startup-config", "description": "保存配置到Flash", "mode": "特权模式"},
        {"name": "查看运行配置", "syntax": "show running-config [section <filter>|diff]", "example": "show running-config diff", "description": "查看运行配置（diff显示与启动配置差异）", "mode": "特权模式"},
        {"name": "查看接口", "syntax": "show interfaces [<interface>] status", "example": "show interfaces status", "description": "查看接口状态信息", "mode": "特权模式"},
        {"name": "查看LLDP邻居", "syntax": "show lldp neighbors [detail]", "example": "show lldp neighbors detail", "description": "查看LLDP邻居信息", "mode": "特权模式"},
        {"name": "查看日志", "syntax": "show logging [last <lines>|tail <n>]", "example": "show logging last 50", "description": "查看系统日志", "mode": "特权模式"},
        {"name": "查看环境", "syntax": "show environment [all|power|cooling]", "example": "show environment all", "description": "查看硬件环境状态（温度、风扇、电源）", "mode": "特权模式"}
      ],
      "keywords": ["hostname", "管理接口", "management", "ssh", "ntp", "snmp", "保存", "running-config", "lldp", "日志"]
    }
  }
}
