{
  "vendor": "FiberHome (烽火)",
  "categories": {
    "vlan": {
      "name": "VLAN配置",
      "keywords": [
        "vlan",
        "access",
        "trunk",
        "hybrid",
        "pvid",
        "port link-type",
        "port default vlan",
        "port trunk allow-pass",
        "虚拟局域网"
      ],
      "commands": [
        {
          "name": "进入系统视图",
          "syntax": "system-view",
