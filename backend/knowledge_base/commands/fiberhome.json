          "mode": "用户视图",
          "keywords": [
            "系统视图",
            "配置模式"
          ]
        },
        {
          "name": "批量创建VLAN",
          "syntax": "vlan batch <vlan_ids>",
          "example": "vlan batch 10 20 30",
          "description": "一次性创建多个VLAN，ID之间用空格分隔",
          "mode": "系统视图",
          "keywords": [
            "vlan",
            "批量创建"
          ]
        },
        {
          "name": "创建单个VLAN并进入",
          "syntax": "vlan <vlan_id>",
          "example": "vlan 10",
          "description": "创建单个VLAN并进入VLAN视图",
          "mode": "系统视图",
          "keywords": [
            "vlan",
            "创建"
          ]
        },
        {
          "name": "设置VLAN名称",
          "syntax": "description <name>",
          "example": "description Management",
          "description": "给VLAN设置描述性名称",
          "mode": "VLAN视图",
          "keywords": [
            "vlan",
            "名称",
            "描述"
          ]
        },
        {
          "name": "删除VLAN",
          "syntax": "undo vlan batch <vlan_ids>",
          "example": "undo vlan batch 10 20",
          "description": "删除指定VLAN",
          "mode": "系统视图",
          "keywords": [
            "vlan",
            "删除",
            "undo"
          ]
        },
        {
          "name": "接口设为Access模式",
          "syntax": "port link-type access",
          "example": "interface GigabitEthernet0/0/1\n  port link-type access",
          "description": "将接口设置为Access模式，通常连接终端设备",
          "mode": "接口视图",
          "keywords": [
            "access",
            "link-type"
          ]
        },
        {
          "name": "Access端口加入VLAN",
          "syntax": "port default vlan <vlan_id>",
          "example": "port default vlan 10",
          "description": "将Access端口划入指定VLAN",
          "mode": "接口视图",
          "keywords": [
            "access",
            "default vlan",
            "pvid"
          ]
        },
        {
          "name": "接口设为Trunk模式",
          "syntax": "port link-type trunk",
          "example": "interface GigabitEthernet0/0/1\n  port link-type trunk",
          "description": "将接口设置为Trunk模式，通常用于交换机互联",
          "mode": "接口视图",
          "keywords": [
            "trunk",
            "link-type"
          ]
        },
        {
          "name": "Trunk端口允许VLAN通过",
          "syntax": "port trunk allow-pass vlan <vlan_list>",
          "example": "port trunk allow-pass vlan 10 20 30",
          "description": "设置Trunk端口允许通过的VLAN列表",
          "mode": "接口视图",
          "keywords": [
            "trunk",
            "allow-pass"
          ]
        },
        {
          "name": "接口设为Hybrid模式",
          "syntax": "port link-type hybrid",
          "example": "port link-type hybrid",
          "description": "Hybrid模式可灵活处理Tagged/Untagged VLAN",
          "mode": "接口视图",
          "keywords": [
            "hybrid",
            "link-type"
          ]
        },
        {
          "name": "查看VLAN配置",
          "syntax": "display vlan [vlan_id]",
          "example": "display vlan 10",
          "description": "查看VLAN信息和端口归属",
          "mode": "任意视图",
          "keywords": [
            "display",
            "vlan",
            "查看"
          ]
        },
        {
          "name": "查看接口VLAN信息",
          "syntax": "display port vlan [interface]",
          "example": "display port vlan GigabitEthernet0/0/1",
          "description": "查看指定接口的VLAN配置信息",
          "mode": "任意视图",
          "keywords": [
            "display",
            "port vlan"
          ]
        }
      ]
    },
    "stp": {
      "name": "STP/MSTP配置",
      "keywords": [
        "stp",
        "rstp",
        "mstp",
        "生成树",
        "根桥",
        "root",
        "边缘端口",
        "bpdu",
        "环路保护"
      ],
      "commands": [
        {
          "name": "启用STP",
          "syntax": "stp enable",
          "example": "stp enable",
          "description": "全局启用STP协议",
          "mode": "系统视图",
          "keywords": [
            "stp",
            "enable",
            "启用"
          ]
        },
        {
          "name": "设置STP模式",
          "syntax": "stp mode {stp|rstp|mstp}",
          "example": "stp mode rstp",
          "description": "选择生成树协议模式：STP/RSTP/MSTP",
          "mode": "系统视图",
          "keywords": [
            "stp",
            "mode",
            "rstp",
            "mstp"
          ]
        },
        {
          "name": "配置MST域",
          "syntax": "stp region-configuration",
          "example": "stp region-configuration\n  region-name REGION\n  revision-level 1\n  instance 1 vlan 10 20\n  active region-configuration",
          "description": "进入MST域配置，设置域名、修订级别和实例VLAN映射",
          "mode": "系统视图",
          "keywords": [
            "mstp",
            "region",
            "instance"
          ]
        },
        {
          "name": "设置根桥",
          "syntax": "stp root primary",
          "example": "stp instance 1 root primary",
          "description": "将交换机设置为指定实例的根桥",
          "mode": "系统视图",
          "keywords": [
            "stp",
            "root",
            "primary",
            "根桥"
          ]
        },
        {
          "name": "设置STP优先级",
          "syntax": "stp priority <0-61440 step 4096>",
          "example": "stp priority 4096",
          "description": "设置交换机STP优先级，值越小越优先",
          "mode": "系统视图",
          "keywords": [
            "stp",
            "priority",
            "优先级"
          ]
        },
        {
          "name": "启用边缘端口",
          "syntax": "stp edged-port enable",
          "example": "stp edged-port enable",
          "description": "将接口设为边缘端口，立即转发不参与STP计算",
          "mode": "接口视图",
          "keywords": [
            "stp",
            "edged-port",
            "边缘端口"
          ]
        },
        {
          "name": "启用BPDU保护",
          "syntax": "stp bpdu-protection",
          "example": "stp bpdu-protection",
          "description": "边缘端口收到BPDU后自动shutdown，防止意外环路",
          "mode": "系统视图",
          "keywords": [
            "stp",
            "bpdu",
            "保护"
          ]
        },
        {
          "name": "启用根保护",
          "syntax": "stp root-protection",
          "example": "stp root-protection",
          "description": "在指定端口上启用根保护，防止根桥切换",
          "mode": "接口视图",
          "keywords": [
            "stp",
            "root-protection",
            "根保护"
          ]
        },
        {
          "name": "查看STP状态",
          "syntax": "display stp [instance <id>] [brief]",
          "example": "display stp brief",
          "description": "查看生成树状态和端口角色",
          "mode": "任意视图",
          "keywords": [
            "display",
            "stp",
            "查看"
          ]
        }
      ]
    },
