          "description": "设置LACP系统优先级",
          "mode": "全局配置",
          "keywords": [
            "lacp",
            "system-priority"
          ]
        },
        {
          "name": "设置最小活动链路数",
          "syntax": "port-channel min-links <num>",
          "example": "port-channel min-links 2",
          "description": "设置聚合组最少活动链路数，低于此数聚合组down",
