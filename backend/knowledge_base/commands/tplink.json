    "acl": {
      "name": "ACL/安全配置",
      "keywords": [
        "acl",
        "access-list",
        "访问控制",
        "permit",
        "deny",
        "端口安全",
        "port-security",
        "流量过滤"
      ],
      "commands": [
        {
          "name": "创建标准ACL",
          "syntax": "access-list <1-99> {permit|deny} <src_ip> <wildcard>",
          "example": "access-list 10 permit 192.168.1.0 0.0.0.255",
          "description": "创建标准ACL，仅匹配源IP地址",
          "mode": "全局配置",
          "keywords": [
            "access-list",
            "标准ACL"
          ]
        },
        {
          "name": "创建扩展ACL",
          "syntax": "access-list <100-199> {permit|deny} ip <src_ip> <wc> <dst_ip> <wc>",
          "example": "access-list 100 deny ip 192.168.1.0 0.0.0.255 any",
          "description": "创建扩展ACL，可匹配五元组",
          "mode": "全局配置",
          "keywords": [
            "access-list",
            "扩展ACL"
          ]
        },
        {
          "name": "接口应用ACL(inbound)",
          "syntax": "ip access-group <acl_id> in",
          "example": "ip access-group 100 in",
          "description": "在接口入方向应用ACL进行流量过滤",
          "mode": "接口配置",
          "keywords": [
            "ip access-group",
            "in"
          ]
        },
        {
          "name": "接口应用ACL(outbound)",
          "syntax": "ip access-group <acl_id> out",
          "example": "ip access-group 100 out",
          "description": "在接口出方向应用ACL进行流量过滤",
          "mode": "接口配置",
          "keywords": [
            "ip access-group",
            "out"
          ]
        },
        {
          "name": "启用端口安全",
          "syntax": "switchport port-security",
          "example": "switchport port-security",
          "description": "在接口上启用端口安全功能",
          "mode": "接口配置",
          "keywords": [
            "port-security",
            "switchport"
          ]
        },
        {
          "name": "设置最大MAC数",
          "syntax": "switchport port-security maximum <num>",
          "example": "switchport port-security maximum 5",
          "description": "设置端口安全允许的最大MAC地址数",
          "mode": "接口配置",
          "keywords": [
            "port-security",
            "maximum",
            "mac限制"
          ]
        },
        {
          "name": "启用Sticky MAC",
          "syntax": "switchport port-security mac-address sticky",
          "example": "switchport port-security mac-address sticky",
          "description": "启用Sticky MAC自动绑定学习到的MAC地址",
          "mode": "接口配置",
          "keywords": [
            "port-security",
            "sticky",
            "mac"
          ]
        },
        {
          "name": "设置违规处理方式",
          "syntax": "switchport port-security violation {protect|restrict|shutdown}",
          "example": "switchport port-security violation restrict",
          "description": "设置MAC地址违规时的处理动作",
          "mode": "接口配置",
          "keywords": [
            "port-security",
            "violation"
          ]
        },
        {
          "name": "查看ACL",
          "syntax": "show access-lists [<acl_id>]",
          "example": "show access-lists 100",
          "description": "查看ACL规则列表",
          "mode": "特权模式",
          "keywords": [
            "show",
            "access-lists"
          ]
        },
        {
          "name": "查看端口安全",
          "syntax": "show port-security [interface <if>]",
          "example": "show port-security interface GigabitEthernet0/1",
          "description": "查看端口安全配置和MAC表",
          "mode": "特权模式",
          "keywords": [
            "show",
            "port-security"
          ]
        }
      ]
    },
