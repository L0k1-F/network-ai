{
  "vendor": "TP-LINK",
  "categories": {
    "vlan": {
      "name": "VLAN配置",
      "keywords": [
        "vlan",
        "access",
        "trunk",
        "switchport",
        "allowed vlan",
        "虚拟局域网",
        "native"
      ],
      "commands": [
        {
          "name": "进入特权模式",
          "syntax": "enable",
          "example": "enable",
          "description": "从用户模式进入特权模式",
          "mode": "用户模式",
          "keywords": [
            "enable",
            "特权"
          ]
        },
        {
          "name": "进入全局配置模式",
          "syntax": "configure terminal",
          "example": "configure terminal",
          "description": "从特权模式进入全局配置模式",
          "mode": "特权模式",
          "keywords": [
            "configure terminal",
            "配置"
          ]
        },
        {
          "name": "创建VLAN",
          "syntax": "vlan <vlan_id>",
          "example": "vlan 10",
          "description": "创建单个VLAN并进入VLAN配置模式",
          "mode": "全局配置",
          "keywords": [
            "vlan",
            "创建"
          ]
        },
        {
          "name": "设置VLAN名称",
          "syntax": "name <vlan_name>",
          "example": "name Management",
          "description": "给VLAN设置描述性名称",
          "mode": "VLAN配置",
          "keywords": [
            "vlan",
            "name",
            "名称"
          ]
        },
        {
          "name": "删除VLAN",
          "syntax": "no vlan <vlan_id>",
          "example": "no vlan 10",
          "description": "删除指定VLAN",
          "mode": "全局配置",
          "keywords": [
            "vlan",
            "no",
            "删除"
          ]
        },
        {
          "name": "接口设为Access模式",
          "syntax": "switchport mode access",
          "example": "interface GigabitEthernet0/1\n  switchport mode access",
          "description": "将接口设置为Access模式，通常连接终端设备",
          "mode": "接口配置",
          "keywords": [
            "switchport",
            "access",
            "mode"
          ]
        },
        {
          "name": "Access端口加入VLAN",
          "syntax": "switchport access vlan <vlan_id>",
          "example": "switchport access vlan 10",
          "description": "将Access端口划分到指定VLAN",
          "mode": "接口配置",
          "keywords": [
            "switchport",
            "access vlan"
          ]
        },
        {
          "name": "接口设为Trunk模式",
          "syntax": "switchport mode trunk",
          "example": "interface GigabitEthernet0/1\n  switchport mode trunk",
          "description": "将接口设置为Trunk模式，通常用于交换机互联",
          "mode": "接口配置",
          "keywords": [
            "switchport",
            "mode trunk"
          ]
        },
        {
          "name": "Trunk允许VLAN通过",
          "syntax": "switchport trunk allowed vlan <vlan_list>",
          "example": "switchport trunk allowed vlan 10,20,30",
          "description": "设置Trunk端口允许通过的VLAN列表，逗号分隔",
          "mode": "接口配置",
          "keywords": [
            "switchport",
            "trunk allowed vlan"
          ]
        },
        {
          "name": "设置Native VLAN",
          "syntax": "switchport trunk native vlan <vlan_id>",
          "example": "switchport trunk native vlan 1",
          "description": "设置Trunk端口的Native VLAN",
          "mode": "接口配置",
          "keywords": [
            "switchport",
            "native vlan"
          ]
        },
        {
          "name": "查看VLAN信息",
          "syntax": "show vlan [id <vlan_id>]",
          "example": "show vlan id 10",
          "description": "查看VLAN配置和端口归属信息",
          "mode": "特权模式",
          "keywords": [
            "show",
            "vlan"
          ]
        },
        {
          "name": "查看接口状态",
          "syntax": "show interfaces <interface> switchport",
          "example": "show interfaces GigabitEthernet0/1 switchport",
          "description": "查看接口的VLAN和交换属性",
          "mode": "特权模式",
          "keywords": [
            "show",
            "interface",
            "switchport"
          ]
        }
      ]
    },
    "stp": {
      "name": "STP/MSTP配置",
      "keywords": [
        "stp",
        "rstp",
        "mstp",
        "spanning-tree",
        "生成树",
        "根桥",
        "portfast",
        "bpduguard",
        "环路保护"
      ],
      "commands": [
        {
          "name": "启用STP",
          "syntax": "spanning-tree",
          "example": "spanning-tree",
          "description": "全局启用生成树协议",
          "mode": "全局配置",
          "keywords": [
            "spanning-tree",
            "stp",
            "启用"
          ]
        },
        {
          "name": "设置STP模式",
          "syntax": "spanning-tree mode {stp|rstp|mstp}",
          "example": "spanning-tree mode rstp",
          "description": "选择生成树协议模式",
          "mode": "全局配置",
          "keywords": [
            "spanning-tree",
            "mode",
            "rstp"
          ]
        },
        {
          "name": "设置根桥",
          "syntax": "spanning-tree vlan <vlan_id> root primary",
          "example": "spanning-tree vlan 10 root primary",
          "description": "将交换机设置为指定VLAN的根桥",
          "mode": "全局配置",
          "keywords": [
            "spanning-tree",
            "root primary",
            "根桥"
          ]
        },
        {
          "name": "设置STP优先级",
          "syntax": "spanning-tree vlan <vlan_id> priority <0-61440>",
          "example": "spanning-tree vlan 10 priority 4096",
          "description": "设置交换机STP优先级，值为4096的倍数",
          "mode": "全局配置",
          "keywords": [
            "spanning-tree",
            "priority",
            "优先级"
          ]
        },
        {
          "name": "启用PortFast",
          "syntax": "spanning-tree portfast",
          "example": "spanning-tree portfast",
          "description": "将接口设为边缘端口立即转发",
          "mode": "接口配置",
          "keywords": [
            "spanning-tree",
            "portfast",
            "边缘端口"
          ]
        },
        {
          "name": "启用BPDU Guard",
          "syntax": "spanning-tree bpduguard enable",
          "example": "spanning-tree bpduguard enable",
          "description": "边缘端口收到BPDU后自动err-disable",
          "mode": "接口配置",
          "keywords": [
            "spanning-tree",
            "bpduguard",
            "保护"
          ]
        },
        {
          "name": "启用BPDU Filter",
          "syntax": "spanning-tree bpdufilter enable",
          "example": "spanning-tree bpdufilter enable",
          "description": "在接口上过滤BPDU报文的收发",
          "mode": "接口配置",
          "keywords": [
            "spanning-tree",
            "bpdufilter"
          ]
        },
        {
          "name": "启用根保护",
          "syntax": "spanning-tree guard root",
          "example": "spanning-tree guard root",
          "description": "在指定端口启用根保护，防止根桥切换",
          "mode": "接口配置",
          "keywords": [
            "spanning-tree",
            "guard root",
            "根保护"
          ]
        },
        {
          "name": "查看STP状态",
          "syntax": "show spanning-tree [vlan <vlan_id>]",
          "example": "show spanning-tree vlan 10",
          "description": "查看生成树状态和端口信息",
          "mode": "特权模式",
          "keywords": [
            "show",
            "spanning-tree"
          ]
        }
      ]
    },
    "aggregation": {
      "name": "链路聚合",
