            "etherchannel",
            "summary"
          ]
        },
        {
          "name": "查看Port-Channel详情",
          "syntax": "show interfaces Port-Channel <id>",
          "example": "show interfaces Port-Channel 1",
          "description": "查看聚合接口详细信息",
